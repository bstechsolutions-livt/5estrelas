APP_NAME="5 Estrelas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8090

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Banco PostgreSQL (rodar via docker compose up -d)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=estrelas
DB_USERNAME=estrelas
DB_PASSWORD=estrelas

# Sessão fica no banco em dev. Em produção: redis.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting via Reverb (WebSocket)
BROADCAST_CONNECTION=reverb

FILESYSTEM_DISK=local

# Queue: 'database' em dev (sem worker), 'redis' em produção (com supervisor rodando o worker)
QUEUE_CONNECTION=database

# Cache: 'database' em dev, 'redis' em produção
CACHE_STORE=database

# Redis (instalado nativamente ou via docker compose)
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Reverb (WebSocket server)
REVERB_APP_ID=438026
REVERB_APP_KEY=l519wskqb2za1r5rpo5g
REVERB_APP_SECRET=8g4txcvdmhbprtwhirvs
REVERB_HOST="127.0.0.1"
REVERB_SERVER_HOST="0.0.0.0"
REVERB_SERVER_PORT=8080
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="127.0.0.1"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Mail: log em dev (mensagens caem no storage/logs/laravel.log)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@5estrelas.local"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (S3-compatible) — Backblaze B2 em produção
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Senior ERP — Contas a Pagar (produção: SENIOR_ENABLED=true)
SENIOR_ENABLED=false
# Intervalo do schedule senior:sync-* em minutos (cron */N). Produção: 5.
# Nunca usar 2 em produção — sobrecarrega SOAP/mutex. Ver docs/senior/sync-intervalo-5min.md
SENIOR_SYNC_INTERVAL=5
# Timeout HTTP (segundos) das chamadas SOAP AbertosCP — default 60 (~1 min).
SENIOR_SYNC_HTTP_TIMEOUT=60
# Alias legado (usado se SENIOR_SYNC_HTTP_TIMEOUT não estiver definido):
# SENIOR_CP_TIMEOUT_RESPONSE=60
# SENIOR_TIMEOUT_CONNECT=60
# SENIOR_TIMEOUT_RESPONSE=60

# Push notifications (Firebase) — desativado até cliente entregar credenciais
FCM_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
